# ─────────────────────────────────────────────────────────────────────────────
# Deep Research Agent - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Local LLM (LM Studio / Ollama / any OpenAI-compatible server) ────────────
# Set the base URL of your local LLM server (LM Studio default: port 1234)
LOCAL_LLM_BASE_URL=https://192.168.68.110:1234/v1
# LM Studio accepts any non-empty string as the API key
LOCAL_LLM_API_KEY=lm-studio
# The model name shown in LM Studio (e.g. "llama-3.2-3b-instruct")
LOCAL_LLM_MODEL=local-model

# ── Tavily API Key (required for web search) ─────────────────────────────────
# Free tier available at: https://www.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith API Key (required for LangGraph local server) ──────────────────
# Free to sign up at: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_pt_your_api_key_here

# ── Optional: Cloud LLM Keys (only needed if switching away from local LLM) ──
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
